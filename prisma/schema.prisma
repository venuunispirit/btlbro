generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models ───────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(MEMBER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  quotations    Quotation[]
  activityLogs  ActivityLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Brand & Project ───────────────────────────────────────────

model Brand {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  logo         String?
  description  String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  quotations   Quotation[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  brandId     String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  brand         Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  quotations    Quotation[]
  presentations Presentation[]
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

// ─── Vendor & Services ─────────────────────────────────────────

model Vendor {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  logo         String?
  description  String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  website      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  services     Service[]
  quotationItems QuotationItem[]
}

model Service {
  id          String    @id @default(cuid())
  vendorId    String
  name        String
  description String?
  category    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vendor         Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  priceHistory   PriceHistory[]
  quotationItems QuotationItem[]
}

model PriceHistory {
  id           String   @id @default(cuid())
  serviceId    String
  price        Decimal  @db.Decimal(12, 2)
  currency     String   @default("INR")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt    DateTime @default(now())

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, effectiveFrom])
}

// ─── Quotation ─────────────────────────────────────────────────

model Quotation {
  id           String          @id @default(cuid())
  quoteNumber  String          @unique
  projectId    String
  brandId      String
  title        String
  status       QuotationStatus @default(DRAFT)
  validUntil   DateTime?
  subtotal     Decimal         @db.Decimal(12, 2) @default(0)
  taxRate      Decimal         @db.Decimal(5, 2)  @default(18)
  taxAmount    Decimal         @db.Decimal(12, 2) @default(0)
  totalAmount  Decimal         @db.Decimal(12, 2) @default(0)
  currency     String          @default("INR")
  terms        String?         @db.Text
  notes        String?         @db.Text
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  brand     Brand            @relation(fields: [brandId], references: [id], onDelete: Cascade)
  creator   User             @relation(fields: [createdBy], references: [id])
  items     QuotationItem[]
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model QuotationItem {
  id           String   @id @default(cuid())
  quotationId  String
  serviceId    String?
  vendorId     String?
  description  String
  quantity     Decimal  @db.Decimal(10, 2) @default(1)
  unitPrice    Decimal  @db.Decimal(12, 2)
  totalPrice   Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  service   Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  vendor    Vendor?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
}

// ─── Presentation ──────────────────────────────────────────────

model Presentation {
  id          String            @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      PresentationStatus @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slides  Slide[]
}

enum PresentationStatus {
  DRAFT
  COMPLETED
}

model Slide {
  id             String     @id @default(cuid())
  presentationId String
  order          Int
  transition     SlideTransition @default(FADE)
  background     String     @default("#ffffff")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  presentation Presentation     @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  elements     SlideElement[]
}

enum SlideTransition {
  FADE
  SLIDE
  ZOOM
  NONE
}

model SlideElement {
  id       String           @id @default(cuid())
  slideId  String
  type     SlideElementType
  x        Float            @default(0)
  y        Float            @default(0)
  width    Float            @default(100)
  height   Float            @default(50)
  zIndex   Int              @default(0)
  content  Json             @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slide Slide @relation(fields: [slideId], references: [id], onDelete: Cascade)
}

enum SlideElementType {
  TEXT
  IMAGE
  SHAPE
}

// ─── Activity Log ──────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  module    String
  entityId  String?
  entityType String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([module, createdAt])
}
